#!/bin/sh

# Run Prettier on staged files before committing
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.js' '*.json' '*.css' '*.md' '*.mjs')

if [ -n "$STAGED_FILES" ]; then
  echo "Running Prettier on staged files..."
  echo "$STAGED_FILES" | xargs npx prettier --write

  # Re-stage formatted files
  echo "$STAGED_FILES" | xargs git add
fi

# Run unit tests
echo "Running unit tests..."
pnpm test
if [ $? -ne 0 ]; then
  echo "Tests failed. Please fix failing tests before committing."
  exit 1
fi

# Run linter
echo "Running linter..."
pnpm lint:fix
if [ $? -ne 0 ]; then
  echo "Lint failed. Please fix lint errors before committing."
  exit 1
fi

exit 0
