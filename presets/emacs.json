{
    "name": "Emacs",
    "description": "Standard Emacs keybindings",
    "version": "1.0.0",
    "hotkeys": [
        { "command": "editor:forward-char", "key": "ctrl+f" },
        { "command": "editor:backward-char", "key": "ctrl+b" },
        { "command": "editor:next-line", "key": "ctrl+n" },
        { "command": "editor:previous-line", "key": "ctrl+p" },
        { "command": "editor:move-beginning-of-line", "key": "ctrl+a" },
        { "command": "editor:move-end-of-line", "key": "ctrl+e" },
        { "command": "editor:forward-word", "key": "alt+f" },
        { "command": "editor:backward-word", "key": "alt+b" },
        { "command": "editor:scroll-up", "key": "ctrl+v" },
        { "command": "editor:scroll-down", "key": "alt+v" },
        { "command": "editor:beginning-of-buffer", "key": "shift+alt+," },
        { "command": "editor:end-of-buffer", "key": "shift+alt+." },
        { "command": "editor:kill-line", "key": "ctrl+k" },
        { "command": "editor:kill-region", "key": "ctrl+w" },
        { "command": "editor:kill-word", "key": "alt+d" },
        { "command": "editor:backward-kill-word", "key": "alt+backspace" },
        { "command": "editor:copy-region", "key": "alt+w" },
        { "command": "editor:yank", "key": "ctrl+y" },
        { "command": "editor:yank-pop", "key": "alt+y" },

        { "command": "editor:delete-char", "key": "ctrl+d" },
        { "command": "editor:transpose-chars", "key": "ctrl+t" },
        { "command": "editor:open-line", "key": "ctrl+o" },

        { "command": "editor:upcase-word", "key": "alt+u" },
        { "command": "editor:downcase-word", "key": "alt+l" },
        { "command": "editor:upcase-region", "key": "ctrl+x ctrl+u" },
        { "command": "editor:downcase-region", "key": "ctrl+x ctrl+l" },

        { "command": "editor:keyboard-quit", "key": "ctrl+g" },
        { "command": "editor:recenter-top-bottom", "key": "ctrl+l" },
        { "command": "editor:undo", "key": "ctrl+/" },
        { "command": "editor:undo", "key": "ctrl+x u" },

        {
            "command": "suggest:next-option",
            "key": "ctrl+n",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:prev-option",
            "key": "ctrl+p",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:forward-char",
            "key": "ctrl+f",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:backward-char",
            "key": "ctrl+b",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:forward-word",
            "key": "alt+f",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:backward-word",
            "key": "alt+b",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:move-beginning-of-line",
            "key": "ctrl+a",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:move-end-of-line",
            "key": "ctrl+e",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:delete-char",
            "key": "ctrl+d",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:kill-line",
            "key": "ctrl+k",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:kill-word",
            "key": "alt+d",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:backward-kill-word",
            "key": "alt+backspace",
            "when": "suggestModalOpen"
        },
        {
            "command": "suggest:yank",
            "key": "ctrl+y",
            "when": "suggestModalOpen"
        }
    ]
}
